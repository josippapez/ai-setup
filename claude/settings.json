{
  "permissions": {
    "allow": [
      "mcp__pencil"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty' 2>/dev/null); [ -n \"$f\" ] || exit 0; case \"$f\" in *.ts|*.tsx|*.js|*.jsx|*.mjs|*.cjs) ;; *) exit 0 ;; esac; [ -x ./node_modules/.bin/eslint ] || exit 0; ./node_modules/.bin/eslint --fix \"$f\" >/dev/null 2>&1; ./node_modules/.bin/eslint \"$f\" 2>/dev/null || true",
            "timeout": 120,
            "statusMessage": "Linting edited file"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/josippapez/.claude/statusline-command.sh"
  },
  "extraKnownMarketplaces": {
    "ai-setup": {
      "source": {
        "source": "directory",
        "path": "/Users/josippapez/Desktop/ai-setup/claude"
      }
    }
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "verbose": false,
  "mcpServers": {
    "interactive-desktop": {
      "url": "http://localhost:3100"
    },
    "interactive": {
      "command": "npx",
      "args": [
        "-y",
        "@rawwee/interactive-mcp",
        "-t",
        "1200",
        "--disable-tools",
        "message_complete_notification"
      ],
      "type": "stdio"
    }
  },
  "enabledPlugins": {
    "interactive-mcp@ai-setup": true
  }
}
